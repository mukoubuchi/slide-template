%%------------------------------------------------------------------
%% 3. Beamer テーマ・テンプレート
%%    タイトルページ・ヘッダ・進捗サークルは AAU Simple Beamer Theme
%%    v1.3.2 (Copyright (c) 2014 Jesper Kjær Nielsen, GPL v3+) を
%%    統合・簡素化したもの
%%------------------------------------------------------------------
\RequirePackage{calc} % 長さ演算 (ヘッダ寸法・フレームタイトル幅)

% structure 色は themeprimary を名前参照 (\usecolortheme[named=...] は読み込み時に
% 色を確定させるため \slidetheme での切り替えが効かない。setbeamercolor は使用時解決)
\setbeamercolor*{structure}{fg=themeprimary}
\setbeamercovered{transparent}
\setbeamertemplate{blocks}[rounded][shadow=true]
% frametitle の白文字/基調色地 (旧 beamerthemesplit が与えていた配色)
\setbeamercolor{frametitle}{fg=white,bg=themeprimary}
\setbeamercolor{framesubtitle}{fg=white}
\setbeamercolor{primary}{fg=white,bg=themeprimary}
\setbeamercolor{secondary}{fg=white,bg=themeaccent}
\setbeamercolor{logo}{bg=white}
\setbeamercolor{AAUsimple}{use={structure,palette sidebar primary},fg=themeaccent,bg=structure.fg}

\setbeamertemplate{navigation symbols}{} % ナビゲーション記号は非表示
\setbeamertemplate{footline}{}           % フッタなし (ヘッダのみ使用)
\setbeamertemplate{bibliography item}[text] % 参考文献マークは番号

% カスタマイズ用フック (本体で \renewcommand して変更する)
\providecommand{\aauemail}{メールアドレス}         % ヘッダのメールアドレス (既定はリンク無効のプレースホルダ)
\providecommand{\aauemailicon}{Figs/email}        % メールアイコン画像
\providecommand{\aaulogo}{Figs/agu}               % 右上サークル内のロゴ画像
\providecommand{\aauevent}{}                      % 表紙最下部の「# イベント名」(空なら非表示)

% ヘッダのメール表記: \aauemail が実アドレス (@ を含む) のときだけ mailto リンクを張る
% (「メールアドレス」等のプレースホルダのままならリンク無効のただの文字列)
\newcommand{\aauemailmailto}[1]{\href{mailto:\aauemail}{#1}}
\ExplSyntaxOn
\NewDocumentCommand { \aauemailhref } { m }
  {
    \str_set:Nx \l_tmpa_str { \aauemail }
    \str_if_in:NnTF \l_tmpa_str { @ }
      { \aauemailmailto { #1 } }
      { #1 }
  }
\ExplSyntaxOff

\makeatletter
% ヘッダ寸法 (この時点の frametitle フォントの行送りを基準にする)
\newlength{\beamer@height}
\usebeamerfont{frametitle}
\setlength{\beamer@height}{2.5\baselineskip}
\reset@font
% ヘッダ帯の高さ (本文から参照する公開名。帯は本文領域に重なって描画される)
\newlength{\aauheaderheight}
\setlength{\aauheaderheight}{\beamer@height}
\newlength{\beamer@logoradius}
\setlength{\beamer@logoradius}{0.95\beamer@height/2}
\newlength{\beamer@borderwidth}
\setlength{\beamer@borderwidth}{2mm}
\newlength{\beamer@logoinnerradius}
\setlength{\beamer@logoinnerradius}{1.1\beamer@logoradius}
\newlength{\beamer@logoouterradius}
\setlength{\beamer@logoouterradius}{\beamer@logoinnerradius+\beamer@borderwidth}
\newlength{\beamer@counterradius}
\setlength{\beamer@counterradius}{\beamer@logoinnerradius/2+\beamer@logoouterradius/2}

% タイトルページ (構成: タイトルボックス / 日付 / 著者 / 所属テキスト / 所属ロゴ / # イベント名)
\newlength{\aau@titleheight}
\setbeamertemplate{title page}{%
  % イベント枠がある場合はその高さの分だけ本文領域を上に詰める
  \ifdefempty{\aauevent}{\setlength{\aau@titleheight}{\textheight}}{\setlength{\aau@titleheight}{\textheight-2em}}%
  \begin{minipage}[c][\aau@titleheight][c]{\textwidth}
    \vfill
    \centering
    \begin{beamercolorbox}[wd=\textwidth,center,sep=\baselineskip,rounded=true,shadow=true]{frametitle}
      \fontsize{18pt}{13pt}\selectfont{\textbf{\inserttitle}}\\
      {\insertsubtitle}
    \end{beamercolorbox}\vspace*{\baselineskip}
    \begin{center}
      {\usebeamerfont{date}\insertdate}\vspace*{\baselineskip}

      {\usebeamerfont{author}\insertauthor}\vspace*{0.5\baselineskip}

      {\usebeamerfont{institute}\insertinstitute}

      {\inserttitlegraphic}
    \end{center}
    \vfill
  \end{minipage}%
  % イベント名: 文字長に応じて伸縮する濃緑の枠 (白文字, 下端はスライド下端に一致)
  \ifdefempty{\aauevent}{}{%
    \begin{tikzpicture}[remember picture, overlay]
      \node[fill=themeprimary, text=white, anchor=south, inner xsep=0.5em, inner ysep=0.3ex]
        at (current page.south) {\usebeamerfont{author}\footnotesize\aauevent};
    \end{tikzpicture}}
}

% ヘッダ (著者・メール・タイトルの帯 + 背景)
\setbeamertemplate{headline}{%
  \begin{beamercolorbox}[wd=1.0\paperwidth,ht=2.25ex,dp=1ex,left]{headfoot}%
      \usebeamerfont{section in head/foot}\hspace*{3.5ex}%
      \insertshortauthor\ (\raisebox{-0.4ex}{\includegraphics[height=2ex]{\aauemailicon}}~\aauemailhref{\textcolor{themeaccent}{\texttt{\aauemail}}}) \ |\ %
              \insertshorttitle%
  \end{beamercolorbox}%
  \aauheaderbackground%
}

% フレームタイトル (右上のロゴを避けた幅で組む)
\setbeamertemplate{frametitle}{%
  \ifx\insertframesubtitle\@empty%
  \begin{minipage}[c][\beamer@height][c]{\textwidth-1.5\beamer@logoouterradius}
    {\usebeamercolor[fg]{frametitle}\usebeamerfont{frametitle}\insertframetitle\par}%
  \end{minipage}
  \else
  \begin{minipage}[t][\beamer@height][t]{\textwidth-1.5\beamer@logoouterradius}
    {\usebeamercolor[fg]{frametitle}\usebeamerfont{frametitle}\insertframetitle\par}%
    {\usebeamercolor[fg]{framesubtitle}\usebeamerfont{framesubtitle}\insertframesubtitle\par}%
  \end{minipage}
  \fi
}

% ヘッダ背景: 基調色の帯 + 右上のロゴサークル + 進捗アークとページ番号
\newcommand{\aauheaderbackground}{%
  \begin{tikzpicture}[overlay]
    \coordinate (UL) at (0,0);                     % スライド左上
    \coordinate (HLR) at (\paperwidth,-\beamer@height); % ヘッダ右下
    \coordinate (logopos) at ([shift={(-\beamer@logoouterradius-\beamer@borderwidth,0.5\beamer@height)}] HLR);
    {\usebeamercolor{AAUsimple}%
      \usebeamercolor{normal text}%
      \draw[draw=none,fill=themeprimary] (UL) rectangle (HLR);
      \fill[fill=themeprimary] (logopos) circle (\beamer@logoouterradius);
      \fill[fill=normal text.bg] (logopos) circle (\beamer@logoinnerradius);
      % ロゴは白円でクリップ (正方形画像でも角がリングにはみ出さない)
      \begin{scope}
        \clip (logopos) circle (\beamer@logoinnerradius);
        \node at (logopos) {\includegraphics[width=2\beamer@logoradius]{\aaulogo}};
      \end{scope}
      % 進捗アーク (フレーム番号 / 総フレーム数)
      \pgfmathsetmacro{\progress}{360*\insertframenumber/\inserttotalframenumber}
      \draw[color=themeaccent,line width=0.5*\beamer@borderwidth] ([xshift=\beamer@counterradius] logopos) arc[radius=\beamer@counterradius, start angle=0, end angle=\progress];
      \fill[fill=white] ([shift={(\progress:\beamer@counterradius)}] logopos) circle (0.5\beamer@borderwidth);
      \node[fill=normal text.bg,draw=AAUsimple.fg,ultra thick,circle,minimum width=2*\beamer@borderwidth] at ([xshift=\beamer@counterradius]logopos) {{\usebeamercolor[fg]{themeprimary}\insertframenumber}};
    }
  \end{tikzpicture}%
}
\makeatother

% 箇条書き・目次のマーカー
\setbeamertemplate{enumerate items}[circle]
