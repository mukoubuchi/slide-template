\usepackage{tikz}
\usetikzlibrary{
  angles,               % 角度マーク (pic {angle=...})
  arrows, arrows.meta,
  automata,
  calc,
  chains,
  decorations.markings, decorations.text,
  intersections,
  matrix,
  patterns,
  positioning,
  shadows,
  shapes,               % geometric / symbols / misc をまとめて
  shapes.callouts       % 吹き出し
}

% pgf レイヤ (\pie が background/foreground を使用)
\pgfdeclarelayer{background}
\pgfdeclarelayer{foreground}
\pgfsetlayers{background,main,foreground}

% 共通スタイル
\tikzset{
  every picture/.append style={remember picture},
  na/.style={baseline=-.5ex}, % 本文中アンカー用
  arrow/.style={thick,-latex,font=\sffamily},
  % フローチャート
  decision/.style={diamond, very thick, draw=green!50!black!50,
    top color=white, bottom color=green!50!black!20,
    text width=3em, text badly centered, inner sep=0pt, minimum size=3em, font=\footnotesize},
  block/.style={rectangle, very thick, draw=blue!50!black!50,
    top color=white, bottom color=blue!50!black!20,
    text width=4em, text centered, rounded corners, font=\footnotesize, minimum height=1em},
  line/.style={draw=black, -stealth},
  terminal/.style={ellipse, draw=red!50!black!50, very thick,
    top color=white, bottom color=red!50!black!20, font=\footnotesize},
  record/.style={cloud, aspect=2, very thick, text centered, draw=yellow!50!black!50,
    top color=white, bottom color=yellow!50!black!20, text width=8em, inner sep=-5pt, font=\footnotesize},
  bomb/.style={starburst, aspect=2, very thick, text centered, draw=red!50!black!50,
    top color=white, bottom color=yellow!50!black!20, text width=8em, inner sep=1pt, font=\footnotesize},
  % ゴールグラフ
  big dot/.style={circle, draw, inner sep=0pt, minimum size=3mm, fill=yellow, font=\footnotesize},
  input/.style={draw, trapezium, trapezium left angle=60, trapezium right angle=120,
    line width=1.2pt, fill={rgb:black,1;white,2}, font=\footnotesize},
  obstacle/.style={draw, trapezium, trapezium left angle=120, trapezium right angle=60,
    line width=1.2pt, fill={rgb:black,1;white,2}, font=\footnotesize},
  flash/.style args={#1:#2}{postaction=decorate, font=\footnotesize, decoration={name=markings,
      mark=at position #1 with {%
        \draw[fill=#2, line width=.75\pgflinewidth, line cap=round, line join=round]
        (+\pgflinewidth,+7\pgflinewidth)   -- ++ ( left:+2\pgflinewidth)
        -- (+-4\pgflinewidth,+-\pgflinewidth) -- ++ (right:+5\pgflinewidth)
        -- (+-\pgflinewidth,+-7\pgflinewidth) -- ++ (right:+2\pgflinewidth)
        -- (+4\pgflinewidth,\pgflinewidth)    -- ++ (left:+5\pgflinewidth)
        -- cycle;}}
  },
  % コネクタ
  connector/.style={-latex, font=\scriptsize},
  rectangle connector/.style={connector,
    to path={(\tikztostart) -- ++(#1,0pt) \tikztonodes |- (\tikztotarget) }, pos=0.5},
  rectangle connector/.default=-2cm,
  straight connector/.style={connector, to path=--(\tikztotarget) \tikztonodes}
}

% 本文中の語をノード化して矢印で結ぶ (\marknode で印を付け \connectnodes で接続)
\newcommand{\marknode}[2]{\tikz[baseline=(#1.base)]\node[na,fill=themeaccent](#1){#2};}
\newcommand{\marknodered}[2]{\tikz[baseline=(#1.base)]\node[na,fill=red!20](#1){#2};}
\newcommand{\marknodegreen}[2]{\tikz[baseline=(#1.base)]\node[na,fill=green!20](#1){#2};}
\newcommand{\marknodeblue}[2]{\tikz[baseline=(#1.base)]\node[na,fill=blue!20](#1){#2};}
\newcommand{\marknodeyellow}[2]{\tikz[baseline=(#1.base)]\node[na,fill=yellow!20](#1){#2};}
\newcommand{\connectnodes}[5][thick]{\begin{tikzpicture}[overlay]\path[->,#1](#2) edge [out=#4, in=#5] (#3);\end{tikzpicture}}

% 3 点で挟まれた角の円弧
\newcommand\anglearc[4]{\begin{scope}[very thick]
    \clip (#1)--(#2)--(#3)--cycle;
    \draw(#1)circle(#4);\end{scope}}

% 1 つの吹き出しから複数のポインタを出す
% 使用例: \path[multiple absolute pointers={[fill=themeaccent, above of=X]{A.north, B.north}{text}}];
\makeatletter
\tikzset{
  expand me/.style={#1},
  multiple absolute pointers/.style args={#1[#2]#3#4}{
    insert path={
      \foreach \qrr@tikz@calloutabsolutepointer in {#3} {
        \pgfextra
          \expandafter\pgfutil@ifnextchar\expandafter[%
          \expandafter\qrr@tikz@parse@calloutabsolutepointer\expandafter{%
          \expandafter\qrr@tikz@parse@calloutabsolutepointer\expandafter[\expandafter]\expandafter}\qrr@tikz@calloutabsolutepointer\@qrr@tikz@parse@calloutabsolutepointer
        \endpgfextra
        node[#2, shape/.expanded=\tikz@shape\space callout, expand me/.expanded=\qrr@tikz@calloutabsolutepointer@options, callout absolute pointer={(\qrr@tikz@calloutabsolutepointer@)}] {#4}
      }
      \pgfextra
        \def\pgf@tempa{#1}
        \pgfutil@in@*{#1}
        \ifpgfutil@in@\else
          \pgfkeysalso{insert path={node[#2] {#4}}}
        \fi
      \endpgfextra}}}

\def\qrr@tikz@parse@calloutabsolutepointer[#1]#2\@qrr@tikz@parse@calloutabsolutepointer{%
  \gdef\qrr@tikz@calloutabsolutepointer@options{#1}%
  \gdef\qrr@tikz@calloutabsolutepointer@{#2}%
}
\makeatother

% 円グラフ・棒グラフ
\tikzset{
  chart/.style={
    legend label/.style={font={\scriptsize},anchor=west,align=left},
    legend box/.style={rectangle, draw, minimum size=5pt},
    axis/.style={black,semithick,->},
    axis label/.style={anchor=east,font={\tiny}},
  },
  bar chart/.style={
    chart,
    bar width/.code={
      \pgfmathparse{##1/2}
      \global\let\bar@w\pgfmathresult
    },
    bar/.style={very thick, draw=white},
    bar label/.style={font={\bf\small},anchor=north},
    bar value/.style={font={\footnotesize}},
    bar width=.75,
  },
  pie chart/.style={
    chart,
    slice/.style={line cap=round, line join=round, very thick, draw=white},
    pie title/.style={font={\bf}},
    pie values/.style={font={\footnotesize}},
    slice type/.style 2 args={
      ##1/.style={fill=##2},
      values of ##1/.style={}
    }
  }
}

\newcommand{\pie}[3][]{
    \begin{scope}[#1]
    \pgfmathsetmacro{\curA}{90}
    \pgfmathsetmacro{\r}{1}
    \def\c{(0,0)}
    \node[pie title] at (90:1.3) {#2};
    \foreach \v/\s in{#3}{
        \pgfmathsetmacro{\deltaA}{\v/100*360}
        \pgfmathsetmacro{\nextA}{\curA + \deltaA}
        \pgfmathsetmacro{\midA}{(\curA+\nextA)/2}

        \path[slice,\s] \c
            -- +(\curA:\r)
            arc (\curA:\nextA:\r)
            -- cycle;
        \pgfmathsetmacro{\d}{max((\deltaA * -(.5/50) + 1) , .5)}

        \begin{pgfonlayer}{foreground}
        \path \c -- node[pos=\d,pie values,values of \s]{$\v\%$} +(\midA:\r);
        \end{pgfonlayer}

        \global\let\curA\nextA
    }
    \end{scope}
}

\newcommand{\legend}[2][]{
    \begin{scope}[#1]
    \path
        \foreach \n/\s in {#2}
            {
                  ++(0,-10pt) node[\s,legend box] {} +(5pt,0) node[legend label] {\n}
            }
    ;
    \end{scope}
}

% キーボードのキー表示
\newcommand*\keystroke[1]{%
  \tikz[baseline=(key.base)]
    \node[%
      draw,
      fill=white,
      drop shadow={shadow xshift=0.25ex,shadow yshift=-0.25ex,fill=black,opacity=0.75},
      rectangle,
      rounded corners=2pt,
      inner sep=1pt,
      line width=0.5pt,
      font=\scriptsize\sffamily
    ](key) {#1\strut}
  ;
}

