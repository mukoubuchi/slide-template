%%==================================================================
%% slidestyle.sty --- スライド共通設定 (XeLaTeX + Beamer)
%%
%% 構成:
%%   1. フォント (欧文・和文)
%%   2. 配色
%%   3. Beamer テーマ・テンプレート
%%   4. Beamer 要素のフォント
%%   5. TikZ (ライブラリ・スタイル・チャート)
%%   6. 数式
%%   7. 強調・バッジ等のマクロ
%%   8. ブロック環境・箇条書き
%%   9. 脚注・参考文献
%%  10. その他 (URL 折り返し・ナビゲーション制御)
%%==================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidestyle}[2026/07/06 v2.3 common slide style]

%%------------------------------------------------------------------
%% 1. フォント
%%------------------------------------------------------------------
\usefonttheme{professionalfonts}
\usepackage{fontspec}
\usepackage{xeCJK} % 和文組版 (禁則・和欧文間処理)

% 和文・欧文とも丸ゴシック。Rounded-X Mgen+ が無い環境ではヒラギノ丸ゴにフォールバック
\IfFontExistsTF{Rounded-X Mgen+ 1cp}{%
  \setmainfont{Rounded-X Mgen+ 1cp}%
  \setsansfont{Rounded-X Mgen+ 1cp}%
  \setCJKmainfont{Rounded-X Mgen+ 1cp}%
  \setCJKsansfont{Rounded-X Mgen+ 1cp}%
}{%
  \setmainfont{Hiragino Maru Gothic ProN}%
  \setsansfont{Hiragino Maru Gothic ProN}%
  \setCJKmainfont{Hiragino Maru Gothic ProN}%
  \setCJKsansfont{Hiragino Maru Gothic ProN}%
}
\IfFontExistsTF{Comic Sans MS}{%
  \setmonofont{Comic Sans MS}%
}{%
  \setmonofont{Menlo}%
}
\IfFontExistsTF{Rounded-X Mgen+ 1mn}{%
  \setCJKmonofont{Rounded-X Mgen+ 1mn}%
}{%
  \setCJKmonofont{Hiragino Maru Gothic ProN}%
}

% 丸ゴシック系フォントにはイタリック体がないため、m/it → m/n にフォールバック宣言
% (参考文献リストの {\em ...} 等で出る "Font shape undefined" 警告を抑制)
\AtBeginDocument{%
  \DeclareFontShape{\encodingdefault}{\rmdefault}{m}{it}{<->ssub*\rmdefault/m/n}{}%
  \DeclareFontShape{\encodingdefault}{\sfdefault}{m}{it}{<->ssub*\sfdefault/m/n}{}%
}

\usepackage{upgreek}      % 直立ギリシャ文字 (\mathup で使用)
\usepackage{anyfontsize}  % 任意サイズの \fontsize

%%------------------------------------------------------------------
%% 2. 配色
%%------------------------------------------------------------------
%% -- テーマカラー (基調色 themeprimary / アクセント themeaccent) --
%% プリアンブルで \slidetheme{<名前>} を呼ぶと切り替わる (既定: oxford)
%%   \slidetheme{oxford}    … Oxford Blue + Cerulean Blue (公式パレット)
%%   \slidetheme{agu}       … 青山学院 濃緑 + 青緑 (公式ロゴ実測色)
%%   \slidetheme{cambridge} … Cambridge Dark Teal + Cambridge Blue (公式パレット)
%%   \slidetheme{mit}       … MIT Red + Silver Gray (公式ペア)
%%   \slidetheme{princeton} … Black + Princeton Orange (公式ペア)
%% 新テーマは <名前>Primary / <名前>Accent の 2 色を \definecolor するだけ
\definecolor{oxfordPrimary}{RGB}{0,33,71}       % Oxford Blue (Pantone 282)
\definecolor{oxfordAccent}{RGB}{73,182,255}     % Oxford Cerulean Blue (公式セカンダリ)
\definecolor{aguPrimary}{RGB}{2,95,61}          % 青山学院 濃緑 (学院公式ロゴ #025F3D)
\definecolor{aguAccent}{RGB}{0,163,132}         % 青山学院 青緑 (大学公式ロゴ #00A384)
\definecolor{cambridgePrimary}{RGB}{19,56,68}   % Cambridge Dark Teal (Pantone 547)
\definecolor{cambridgeAccent}{RGB}{142,232,216} % Cambridge Blue (Pantone 7471)
\definecolor{mitPrimary}{RGB}{163,31,52}        % MIT Red (PMS 201)
\definecolor{mitAccent}{RGB}{138,139,140}       % MIT Silver Gray (PMS 424)
\definecolor{princetonPrimary}{RGB}{0,0,0}      % Princeton Black
\definecolor{princetonAccent}{RGB}{231,117,0}   % Princeton Orange (PMS 158)
\newcommand{\slidetheme}[1]{%
  \colorlet{themeprimary}{#1Primary}%
  \colorlet{themeaccent}{#1Accent}%
}
\slidetheme{oxford}

%% -- 汎用の名前付きカラー ------------------------------------------
