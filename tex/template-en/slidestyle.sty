%% 2. Colors
%%------------------------------------------------------------------
%% -- Theme colors (base themeprimary / accent themeaccent) --------
%% Switch with \slidetheme{<name>} in the preamble (default: oxford)
%%   \slidetheme{oxford}    ... Oxford Blue + Cerulean Blue (official palette)
%%   \slidetheme{agu}       ... Aoyama Gakuin dark green + blue-green (official logo colors)
%%   \slidetheme{cambridge} ... Cambridge Dark Teal + Cambridge Blue (official palette)
%%   \slidetheme{mit}       ... MIT Red + Silver Gray (official pair)
%%   \slidetheme{princeton} ... Black + Princeton Orange (official pair)
%% To add a theme, just \definecolor <name>Primary and <name>Accent
\definecolor{oxfordPrimary}{RGB}{0,33,71}       % Oxford Blue (Pantone 282)
\definecolor{oxfordAccent}{RGB}{73,182,255}     % Oxford Cerulean Blue (official secondary)
\definecolor{aguPrimary}{RGB}{2,95,61}          % Aoyama Gakuin dark green (official logo #025F3D)
\definecolor{aguAccent}{RGB}{0,163,132}         % Aoyama Gakuin blue-green (university logo #00A384)
\definecolor{cambridgePrimary}{RGB}{19,56,68}   % Cambridge Dark Teal (Pantone 547)
\definecolor{cambridgeAccent}{RGB}{142,232,216} % Cambridge Blue (Pantone 7471)
\definecolor{mitPrimary}{RGB}{163,31,52}        % MIT Red (PMS 201)
\definecolor{mitAccent}{RGB}{138,139,140}       % MIT Silver Gray (PMS 424)
\definecolor{princetonPrimary}{RGB}{0,0,0}      % Princeton Black
\definecolor{princetonAccent}{RGB}{231,117,0}   % Princeton Orange (PMS 158)
\newcommand{\slidetheme}[1]{%
  \colorlet{themeprimary}{#1Primary}%
  \colorlet{themeaccent}{#1Accent}%
}
\slidetheme{oxford}

