%%==================================================================
%% slidestyle.sty --- common slide settings (XeLaTeX + Beamer)
%%
%% Layout:
%%   1. Fonts (Latin / CJK)
%%   2. Colors
%%   3. Beamer theme and templates
%%   4. Fonts for Beamer elements
%%   5. TikZ (libraries, styles, charts)
%%   6. Math
%%   7. Emphasis and badge macros
%%   8. Block environments and lists
%%   9. Footnotes and bibliography
%%  10. Misc (URL breaking, navigation control)
%%==================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidestyle}[2026/07/06 v2.3 common slide style]

%%------------------------------------------------------------------
%% 1. Fonts
%%------------------------------------------------------------------
\usefonttheme{professionalfonts}
\usepackage{fontspec}
\usepackage{xeCJK} % CJK typesetting (line breaking, CJK/Latin spacing)

% Rounded gothic for both Latin and CJK; fall back to Hiragino Maru
% Gothic where Rounded-X Mgen+ is not installed
\IfFontExistsTF{Rounded-X Mgen+ 1cp}{%
  \setmainfont{Rounded-X Mgen+ 1cp}%
  \setsansfont{Rounded-X Mgen+ 1cp}%
  \setCJKmainfont{Rounded-X Mgen+ 1cp}%
  \setCJKsansfont{Rounded-X Mgen+ 1cp}%
}{%
  \setmainfont{Hiragino Maru Gothic ProN}%
  \setsansfont{Hiragino Maru Gothic ProN}%
  \setCJKmainfont{Hiragino Maru Gothic ProN}%
  \setCJKsansfont{Hiragino Maru Gothic ProN}%
}
\IfFontExistsTF{Comic Sans MS}{%
  \setmonofont{Comic Sans MS}%
}{%
  \setmonofont{Menlo}%
}
\IfFontExistsTF{Rounded-X Mgen+ 1mn}{%
  \setCJKmonofont{Rounded-X Mgen+ 1mn}%
}{%
  \setCJKmonofont{Hiragino Maru Gothic ProN}%
}

% Rounded gothic fonts have no italic shape, so declare an m/it -> m/n
% fallback (silences "Font shape undefined" warnings from {\em ...}
% in the bibliography and elsewhere)
\AtBeginDocument{%
  \DeclareFontShape{\encodingdefault}{\rmdefault}{m}{it}{<->ssub*\rmdefault/m/n}{}%
  \DeclareFontShape{\encodingdefault}{\sfdefault}{m}{it}{<->ssub*\sfdefault/m/n}{}%
}

\usepackage{upgreek}      % upright Greek letters (used by \mathup)
\usepackage{anyfontsize}  % \fontsize at arbitrary sizes

