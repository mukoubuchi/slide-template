\usepackage{mathtools}
\usepackage{empheq}
\usepackage{bm}
\usepackage{braket}   % \Set
\usepackage{mathrsfs} % script letters \mathscr

\everymath{\displaystyle}

\providecommand{\abs}[1]{\lvert#1\rvert}
\newcommand{\mathitalic}[1]{\mbox{\it{#1}}} % Math ITalic
\newcommand\eqdef{\rotatebox{180}{$\coloneqq$}}         % "=:" (mirror of \defeq)
\newcommand\defeq{\coloneqq}                            % ":="
\newcommand\defiff{\vcentcolon\hspace{-0.5pt}\Leftrightarrow} % ":<=>"
\newcommand\defsubseteq{\vcentcolon\hspace{-0.5pt}\subseteq}  % ":subseteq"
\newcommand*{\perm}[2]{{}_{#1}P_{#2}} % permutations

% Upright math symbols (\mathup{\alpha} etc.)
\DeclareRobustCommand{\mathup}[1]{\begingroup\changegreek\mathrm{#1}\endgroup}
\DeclareRobustCommand{\mathbfup}[1]{\begingroup\changegreekbf\mathbf{#1}\endgroup}
\makeatletter
\def\changegreek{\@for\next:={%
  alpha,beta,gamma,delta,epsilon,zeta,eta,theta,kappa,lambda,mu,nu,xi,pi,rho,sigma,%
  tau,upsilon,phi,chi,psi,omega,varepsilon,vartheta,varpi,varrho,varsigma,varphi}%
  \do{\expandafter\let\csname\next\expandafter\endcsname\csname\next up\endcsname}}
\def\changegreekbf{\@for\next:={%
  alpha,beta,gamma,delta,epsilon,zeta,eta,theta,kappa,lambda,mu,nu,xi,pi,rho,sigma,%
  tau,upsilon,phi,chi,psi,omega,varepsilon,vartheta,varpi,varrho,varsigma,varphi}%
  \do{\expandafter\def\csname\next\expandafter\endcsname\expandafter{%
    \expandafter\bm\expandafter{\csname\next up\endcsname}}}}
\makeatother

% Latin variables in math in upright CMR
\DeclareSymbolFont{mymathvariables}{T1}{cmr}{m}{n}
\DeclareSymbolFontAlphabet{\mathnormal}{mymathvariables}

%%------------------------------------------------------------------
%% 7. Emphasis and badge macros
%%------------------------------------------------------------------
\usepackage{pifont}           % \ding
\usepackage[normalem]{ulem}   % \sout (strikethrough)

% Emphasis
\newcommand{\boldcolor}[1]{\textcolor{themeaccent}{\textbf{#1}}} % Bold Color
\newcommand{\boldred}[1]{\textcolor{red}{\textbf{#1}}}           % Bold Red
\newcommand{\underbold}[1]{\textbf{\textcolor{red}{#1}}}         % underbold (bold red)
\newcommand{\redstrike}[1]{\textcolor{red}{\sout{\textcolor{black}{#1}}}} % red strikethrough

% Arrow symbols
\newcommand{\arrow}{\textcolor{themeaccent}{\ding{220}}}
\newcommand{\whitearrow}{\textcolor{white}{\ding{220}}}
\newcommand{\arrowdown}{\textcolor{themeaccent}{\rotatebox[origin=c]{-90}{\ding{220}}}}

% Paragraph boxes
\newcommand{\nobreakbox}[1]{\parbox{\linewidth}{#1}}                    % prevent inline breaks
\newcommand{\footnotebox}[1]{\vspace{0ex}\parbox[t]{\linewidth-4ex}{#1}} % for footnotes

% Figure captions (turquoise rounded chip)
\newcommand{\captionchip}[1]{\tikz[baseline]{\node[fill=themeaccent,anchor=base,rounded corners](#1){\scriptsize\textcolor{white}{#1}};}}

% Badges
\newcommand{\examplebadge}{\tikz[baseline]{\node[fill=example,anchor=base](ex){\textcolor{white}{\bf Ex}};}} % same green as exampleblock
\newcommand{\notebadge}{\tikz[baseline]{\node[fill=red,anchor=base](note){\textcolor{white}{\bf Note}};}}
\newcommand{\questionbadge}{\tikz[baseline]{\node[fill=themeaccent,anchor=base](q){\textcolor{white}{\bf Q}};}}
\newcommand{\advancedbadge}{\tikz[baseline]{\node[fill=berkeley,anchor=base](adv){\textcolor{white}{\bf Advanced}};}}
\newcommand{\templatebadge}{\tikz[baseline]{\node[fill=harvard,anchor=base](tpl){\textcolor{white}{\bf Template}};}}
\newcommand{\notemplatebadge}{\tikz[baseline]{\node[fill=cambridge,anchor=base](notpl){\textcolor{white}{\bf No template}};}}
\newcommand{\policybadge}{\tikz[baseline]{\node[fill=oxford,anchor=base](policy){\textcolor{white}{\bf Policy}};}}
\newcommand{\answerbadge}{\tikz[baseline]{\node[fill=berkeley,anchor=base](a){\textcolor{white}{\bf A}};}}
\newcommand{\reviewbadge}{\tikz[baseline]{\node[fill=tufts,anchor=base](review){\textcolor{white}{\bf Review}};}}

% Reference enumerate circled numbers with \ref
\newcommand\circleref[1]{%
  \usebeamercolor{enumerate item}%
  \tikzset{beameritem/.style={circle,inner sep=0,minimum size=2ex,text=enumerate item.bg,fill=enumerate item.fg,font=\footnotesize}}%
  \tikz[baseline=(n.base)]\node(n)[beameritem]{\bf\ref{#1}};%
}
\newcommand\circlenum[1]{%
  \usebeamercolor{enumerate item}%
  \tikzset{beameritem/.style={circle,inner sep=0,minimum size=2ex,text=enumerate item.bg,fill=enumerate item.fg,font=\footnotesize}}%
  \tikz[baseline=(n.base)]\node(n)[beameritem]{\bf #1};%
}
\newcommand\trianglebullet{{\footnotesize$\blacktriangleright$}}

% Dashes
\newcommand\dash{\textendash}
\newcommand\emdash{\textemdash}

% Tilted exclamation marks
\newcommand{\exclaim}{\rotatebox[origin=l]{-10}{!}\hspace{-2pt}\rotatebox[origin=l]{-10}{!}\hspace{-2pt}\rotatebox[origin=l]{-10}{!}}
\newcommand{\exclaimwhite}{\color{white}\rotatebox[origin=l]{-10}{!}\hspace{-2pt}\rotatebox[origin=l]{-10}{!}\hspace{-2pt}\rotatebox[origin=l]{-10}{!}}
\newcommand{\exclaimquestion}{\rotatebox[origin=l]{-10}{!}\hspace{-2pt}\rotatebox[origin=l]{-10}{?}}

% Jump button to a labeled frame
\newcommand{\go}[2]{\raisebox{-0ex}{\hyperlink{#1}{\beamergotobutton{#2}}}}

% Cross-references
\newcommand{\tabref}[1]{{\bf Table~\ref{#1}}}
\newcommand{\equref}[1]{Eq.~(\ref{#1})}
\newcommand{\figref}[1]{{\bf Fig.~\ref{#1}}}
\newcommand{\secref}[1]{Sec.~\ref{#1}}
\newcommand{\secrefto}[1]{\ding{42}~Sec.~\ref{#1}}

% Lower table title characters slightly
\newcommand{\lowered}[1]{\raisebox{-1pt}{#1}}

%%------------------------------------------------------------------
%% 8. Block environments, lists, and tables
%%------------------------------------------------------------------
% Block for in-class exercises (orange)
\newenvironment<>{exercise}[1]{%
  \setbeamercolor{block title}{fg=white,bg=princeton}%
  \begin{block}#2{#1}}{\end{block}}

% Block for assignments (yellow)
\newenvironment<>{assignment}[1]{%
  \setbeamercolor{block title}{fg=white,bg=berkeley}%
  \begin{block}#2{#1}}{\end{block}}

% Left margin and item spacing of lists
\setlength{\leftmargini}{1em}
\setbeamertemplate{itemize/enumerate body begin}{%
  \setlength{\leftmargini}{0pt}%
  \setlength{\parsep}{0pt}%
}

% List margins inside blocks
\makeatletter
\addtobeamertemplate{block begin}{%
\def\@listi{\leftmargin3em
  \topsep 3\p@ \@plus2\p@ \@minus2.5\p@
  \parsep 0\p@
  \itemsep3\p@ \@plus2\p@ \@minus3\p@}
}{}
\addtobeamertemplate{block example begin}{%
\def\@listi{\leftmargin2em
  \topsep 3\p@ \@plus2\p@ \@minus2.5\p@
  \parsep 0\p@
  \itemsep3\p@ \@plus2\p@ \@minus3\p@}
}{}
\addtobeamertemplate{block alerted begin}{%
\def\@listi{\leftmargin2em
  \topsep 3\p@ \@plus2\p@ \@minus2.5\p@
  \parsep 0\p@
  \itemsep3\p@ \@plus2\p@ \@minus3\p@}
}{}
\makeatother

% beamer does not define \labelenumi
\def\labelenumi{\theenumi}

% \fbox without frame and padding
\fboxrule=0pt
\fboxsep=0pt

% Tables: thick rules (\thickhline and column specifier I)
\usepackage{array}
\newcolumntype{I}{!{\vrule width 3\arrayrulewidth}}
\newlength\savedwidth
\newcommand\thickhline{%
  \noalign{\xdef\origarrayrulewidth{\the\arrayrulewidth}%
  \global\arrayrulewidth 3\arrayrulewidth}%
  \hline%
  \noalign{\global\arrayrulewidth\origarrayrulewidth}%
}

%%------------------------------------------------------------------
%% 9. Footnotes and bibliography
%%------------------------------------------------------------------
\usepackage{fourier-orns} % ornament for footnote marks (\textxswdown)
\usepackage{nccfoots}     % \Footnote etc.

% Footnote marks: sword ornament + lowercase letter
\makeatletter
\renewcommand\@makefnmark{\hbox{\@textsuperscript{\color{themeaccent}\textxswdown\normalfont\!\@textsubscript{\@thefnmark}}}}
\makeatother
\renewcommand{\thefootnote}{\tt\alph{footnote}}
\setbeamerfont{footnote}{size=\tiny}

% Inline citations as superscript 1), 2)
\makeatletter
\def\@cite#1{\textcolor{themeaccent}{\tt\textsuperscript{\bf{#1})}}}
\def\@biblabel#1{\tt\textcolor{themeaccent}{\bf{#1})}}
\makeatother

% Colors and size of the bibliography list
\setbeamercolor{bibliography entry author}{fg=black,bg=white}
\setbeamerfont{bibliography entry author}{size=\tiny}

