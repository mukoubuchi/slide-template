% goto button colors
\setbeamercolor{button}{bg=themeaccent,fg=white}

% TOC depth (0: chapter, 1: section, 2: subsection, 3: subsubsection)
\setcounter{tocdepth}{3}

% Tighten the spacing between sections in the TOC
\usepackage{etoolbox}
\makeatletter
\patchcmd{\beamer@sectionintoc}{\vskip1.5em}{\vskip0.7em}{}{}
\makeatother

% Automatically insert a TOC slide at every \section
\AtBeginSection[]
{\begin{frame}
    \frametitle{Contents}
    \tableofcontents[hideothersubsections,sectionstyle=show/shaded]
\end{frame}}

